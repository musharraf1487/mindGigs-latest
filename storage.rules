rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars — public read (shown on public profile pages), owner-only write
    match /avatars/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Digital products — readable by any signed-in user, owner-only write
    match /products/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
