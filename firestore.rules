rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — owner can always read/write their own doc; anyone (incl. signed-out
    // visitors) can read an onboarded expert's doc so profiles are publicly visible.
    match /users/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) ||
        (resource.data.role == 'expert' && resource.data.onboardingComplete == true);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Bookings — readable by client or expert involved
    match /bookings/{id} {
      allow read: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.expertId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.expertId == request.auth.uid);
    }

    // Commissions — readable by expert or affiliate involved
    match /commissions/{id} {
      allow read: if request.auth != null &&
        (resource.data.expertId == request.auth.uid ||
         resource.data.affiliateId == request.auth.uid);
    }

    // Referrals — readable by the expert who owns them
    match /referrals/{id} {
      allow read: if request.auth != null &&
        resource.data.expertId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Payout requests — readable/writable by the affiliate/expert who made them
    match /payoutRequests/{id} {
      allow read, write: if request.auth != null &&
        resource.data.affiliateId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Campaigns — readable/writable by the affiliate who owns them
    match /campaigns/{id} {
      allow read, write: if request.auth != null &&
        resource.data.affiliateId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Reviews — public read, authenticated create
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Handles — public username registry, used to enforce uniqueness for
    // expert/affiliate vanity URLs and coupon codes. Public read (needed for
    // pre-signup availability checks); create is atomic and race-free via
    // !exists(), so two users can never claim the same handle. Format and
    // reserved-word checks are enforced here too (not just client-side in
    // handleService.js's RESERVED_HANDLES — keep both lists in sync) so a
    // direct SDK/API call can't bypass them.
    match /handles/{handle} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid &&
        handle.matches('^[a-z][a-z0-9-]{2,29}$') &&
        !(handle in [
          'home', 'landingboard', 'login', 'signup', 'onboarding', 'experts',
          'public-profile', 'booking', 'expert-dashboard', 'admin-dashboard',
          'affiliate-dashboard', 'client-dashboard',
          'admin', 'api', 'dashboard', 'assets', 'www', 'mindgigs', 'settings',
          'help', 'support', 'terms', 'privacy', 'pricing', 'blog', 'ref'
        ]) &&
        !exists(/databases/$(database)/documents/handles/$(handle));
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Platform config — public read, admin write only
    match /config/{id} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin — full access for admin role
    match /{document=**} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
