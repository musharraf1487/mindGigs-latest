rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — owner can always read/write their own doc; anyone (incl. signed-out
    // visitors) can read an onboarded expert's doc so profiles are publicly visible.
    //
    // Admin is intentionally excluded from normal self-service write access:
    // the platform has exactly one admin, provisioned out-of-band (Firebase
    // Console / Admin SDK), which bypasses these rules entirely. No client
    // write — signup, Google sign-in, or a raw SDK call from devtools — may
    // ever create a doc with role == 'admin', and role can never be changed
    // by an update (no legitimate client flow needs to change it, so this
    // blocks self-escalation as well as accidental/malicious demotion).
    match /users/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) ||
        (resource.data.role == 'expert' && resource.data.onboardingComplete == true) ||
        (request.auth != null && resource.data.referredByExpertId == request.auth.uid) ||
        (request.auth != null && resource.data.onboardedByAffiliateId == request.auth.uid);
      allow create: if request.auth != null && request.auth.uid == uid &&
        request.resource.data.role != 'admin';
      allow update: if request.auth != null && request.auth.uid == uid &&
        request.resource.data.role == resource.data.role;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Bookings — readable by client or expert involved
    match /bookings/{id} {
      allow read: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.expertId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.expertId == request.auth.uid);
    }

    // Commissions — readable by the seller, or Person A / Person B (the
    // onboarding affiliate / coupon-or-referral source) involved in the sale
    match /commissions/{id} {
      allow read: if request.auth != null &&
        (resource.data.sellerId == request.auth.uid ||
         resource.data.personAId == request.auth.uid ||
         resource.data.personBId == request.auth.uid);
    }

    // Affiliate coupon codes — doc ID is the code itself, so a collision
    // (writing to an existing code) is denied as an unauthorized "update"
    // (no update rule exists here), making code generation collision-safe.
    // Read is public (like handles/) so a coupon can be pre-validated before
    // the Auth account creating step of signup, avoiding an orphaned account
    // on a doomed code — codes are meant to be shared publicly anyway.
    match /affiliateCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerRole == 'affiliate' &&
        request.resource.data.code == code &&
        code.matches('^[A-Z0-9]{6}$');
    }

    // Payout requests — readable/writable by the affiliate/expert who made them
    match /payoutRequests/{id} {
      allow read, write: if request.auth != null &&
        resource.data.affiliateId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Campaigns — readable/writable by the affiliate who owns them
    match /campaigns/{id} {
      allow read, write: if request.auth != null &&
        resource.data.affiliateId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Purchases — readable by the buyer or the expert who sold the item.
    // Docs are only ever written by the stripeWebhook Cloud Function (Admin
    // SDK bypasses these rules), so no client create/update/delete is needed.
    match /purchases/{id} {
      allow read: if request.auth != null &&
        (resource.data.buyerId == request.auth.uid ||
         resource.data.expertId == request.auth.uid);
    }

    // Reviews — public read, authenticated create
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Handles — public username registry, used to enforce uniqueness for
    // expert/affiliate vanity URLs and coupon codes. Public read (needed for
    // pre-signup availability checks); create is atomic and race-free via
    // !exists(), so two users can never claim the same handle. Format and
    // reserved-word checks are enforced here too (not just client-side in
    // handleService.js's RESERVED_HANDLES — keep both lists in sync) so a
    // direct SDK/API call can't bypass them.
    match /handles/{handle} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid &&
        handle.matches('^[a-z][a-z0-9-]{2,29}$') &&
        !(handle in [
          'home', 'landingboard', 'login', 'signup', 'onboarding', 'experts',
          'public-profile', 'booking', 'expert-dashboard', 'admin-dashboard',
          'affiliate-dashboard', 'client-dashboard',
          'admin', 'api', 'dashboard', 'assets', 'www', 'mindgigs', 'settings',
          'help', 'support', 'terms', 'privacy', 'pricing', 'blog', 'ref'
        ]) &&
        !exists(/databases/$(database)/documents/handles/$(handle));
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Platform config — public read, admin write only
    match /config/{id} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin — full access for admin role
    match /{document=**} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
